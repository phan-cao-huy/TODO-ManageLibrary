@model IEnumerable<ManageLibrary.Models.LibraryCard>

@{
    ViewData["Title"] = "Quản lý Thẻ Thư Viện";
    Layout = "~/Views/Shared/Layout.cshtml";
    var currentFilter = (string?)ViewData["CurrentFilter"] ?? string.Empty;
}

<div class="container-fluid px-4">
    <h1 class="mt-4">@ViewData["Title"]</h1>

    <form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
        <div class="col-sm-8 col-md-9">
            <label for="search" class="form-label">Tìm thẻ (Mã Thẻ / Tên Độc Giả / Trạng Thái)</label>
            <input type="text" class="form-control" id="search" name="search" value="@currentFilter" placeholder="VD: T001, Nguyễn Văn A, Hoạt động" />
        </div>
        <div class="col-sm-4 col-md-3 text-end">
            <div class="d-inline-flex gap-2 flex-nowrap">
                <button type="submit" class="btn btn-primary">Tìm</button>
                <a asp-action="Index" class="btn btn-secondary">Đặt lại</a>
                <a asp-action="Create" class="btn btn-success">Cấp thẻ mới</a>
            </div>
        </div>
    </form>

    <div class="table-responsive" style="max-height:60vh; overflow-y:auto;">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark text-center" style="position: sticky; top: 0; z-index: 1;">
                <tr>
                    <th>Mã Thẻ</th>
                    <th>Độc Giả</th>
                    <th>Ngày Cấp</th>
                    <th>Ngày Hết Hạn</th>
                    <th>Trạng Thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="text-center">
                        <td>@item.CardId</td>
                        <td class="text-start">@(item.Reader != null ? item.Reader.FullName : item.ReaderId)</td>
                        <td>@item.IssueDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.ExpiryDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (item.Status == "Hoạt động")
                            {
                                <span class="badge bg-success">@item.Status</span>
                            }
                            else if (item.Status == "Bị khóa")
                            {
                                <span class="badge bg-danger">@item.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@item.Status</span>
                            }
                        </td>
                        <td class="text-center" style="width: 200px;">
                            <a asp-action="Edit" asp-route-id="@item.CardId" class="btn btn-warning btn-sm" title="Cập nhật">Cập nhật</a>
                            <button type="button" class="btn btn-info btn-sm ms-1" data-bs-toggle="modal"
                                    data-bs-target="#detailsModal-@item.CardId" title="Chi tiết">Chi tiết</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @foreach (var item in Model)
    {
        <div class="modal fade" id="detailsModal-@item.CardId" tabindex="-1" aria-labelledby="modalLabel-@item.CardId" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalLabel-@item.CardId">Chi tiết Thẻ: @item.CardId</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <dl class="row">
                            <dt class="col-sm-4">@Html.DisplayNameFor(model => item.CardId)</dt>
                            <dd class="col-sm-8">@item.CardId</dd>
                            <dt class="col-sm-4">Độc giả</dt>
                            <dd class="col-sm-8">@(item.Reader != null ? item.Reader.FullName : item.ReaderId)</dd>
                            <dt class="col-sm-4">@Html.DisplayNameFor(model => item.IssueDate)</dt>
                            <dd class="col-sm-8">@item.IssueDate.ToString("dd/MM/yyyy")</dd>
                            <dt class="col-sm-4">@Html.DisplayNameFor(model => item.ExpiryDate)</dt>
                            <dd class="col-sm-8">@item.ExpiryDate.ToString("dd/MM/yyyy")</dd>
                            <dt class="col-sm-4">@Html.DisplayNameFor(model => item.Status)</dt>
                            <dd class="col-sm-8">@item.Status</dd>
                            <dt class="col-sm-4">@Html.DisplayNameFor(model => item.Notes)</dt>
                            <dd class="col-sm-8">@item.Notes</dd>
                        </dl>
                    </div>
                    <div class="modal-footer">
                        <a asp-action="Edit" asp-route-id="@item.CardId" class="btn btn-warning">Sửa</a>
                        <form asp-action="Delete" asp-route-id="@item.CardId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa thẻ này không?');">Xóa</button>
                        </form>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
